class Solution {
    public boolean isSameTree(TreeNode p, TreeNode q) {
        
        // both nodes are null
        if (p == null && q == null) {
            return true;
        }

        // one is null and other is not null
        if (p == null || q == null) {
            return false;
        }

        // values are different
        if (p.val != q.val) {
            return false;
        }

        // check left subtree and right subtree
        return isSameTree(p.left, q.left) && isSameTree(p.right, q.right);
    }
}
